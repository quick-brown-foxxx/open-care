# Local development environment — copy to .dev.vars and fill in your values.
# .dev.vars is gitignored. Never commit real secrets.
#
# For staging/production: secrets go into Cloudflare Workers (wrangler secret put)
# and GitHub Actions. See docs/ops/secrets-inventory.md for the full map.

# =============================================================================
# Secrets (local dev: use fake/generated values, never real staging/prod keys)
# =============================================================================

# Operator write auth token — any random string for local dev
OPERATOR_TOKEN=dev-operator-token-change-me

# Helius — use fake values or skip for local dev
HELIUS_API_KEY=skip-helius-key
HELIUS_RPC_URL=https://api.devnet.solana.com
HELIUS_WEBHOOK_AUTH_HEADER=dev-webhook-secret-change-me

# Anchor wallet — generate a local keypair or use devnet throwaway
ANCHOR_WALLET_SECRET=dev-anchor-key-change-me

# Telegram bot - fake values for local mock tests
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TG_WEBHOOK_SECRET=dev-webhook-secret-change-me

# Bot identity protection — generate random 32-byte keys
TG_ID_HMAC_KEY=dev-hmac-key-change-me-32-bytes-min
TG_CHAT_ENC_KEY=dev-aes256-gcm-key-change-me-32-bytes

# =============================================================================
# Env specific values
# =============================================================================

SITE_URL=http://localhost:5173
SOLANA_CLUSTER=localnet
TREASURY_WALLET_ADDRESS=generate-me-for-localnet
VAULT_USDC_ATA=generate-me-for-localnet
ANCHOR_WALLET_ADDRESS=generate-me-for-localnet

# Used only for automatic/manual testing
DONOR_WALLET_SECRET=generate-me-for-localnet

# =============================================================================
# Public config (non-secrets, safe to commit — these are defaults for local dev)
# =============================================================================

USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
CONTACT_URL=https://t.me/your-contact-channel

# =============================================================================
# Staging (devnet) values — used by wrangler.jsonc vars and CI deploy
# =============================================================================
# These are the devnet addresses and config used for the staging environment.
# They are safe to commit (public keys only, no secrets).
#
# SOLANA_CLUSTER=devnet
# USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# TREASURY_WALLET_ADDRESS=8ufYGMkmAWeaYaM4CnANrxLxpQoaESKTGFN1BcgU71tG
# VAULT_USDC_ATA=52MK6GwPWLvjfZuXm3K9fy9PozZAgUAKridA7ycSQUtG
# ANCHOR_WALLET_ADDRESS=BhKtkM1oHADwo8ap5P6Lymj7b3iaspiAm37RA9KMn8YG
# SITE_URL=https://staging.open-care.org

# =============================================================================
# Production (mainnet) values — used by wrangler.jsonc vars with --env production
# =============================================================================
# These are the mainnet addresses and config for the production environment.
# They are safe to commit (public keys only, no secrets).
#
# IMPORTANT: Production secrets (private keys, tokens, API keys) must be set
# manually via `wrangler secret put --env production`. They are NEVER in this
# file. See docs/ops/secrets-inventory.md for the full production secrets list.
#
# SOLANA_CLUSTER=mainnet-beta
# USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# TREASURY_WALLET_ADDRESS=TBD_MAINNET_TREASURY_WALLET
# VAULT_USDC_ATA=TBD_MAINNET_VAULT_USDC_ATA
# ANCHOR_WALLET_ADDRESS=TBD_MAINNET_ANCHOR_WALLET
# SITE_URL=https://open-care.org

# =============================================================================
# E2E test account (Telethon — for automated bot interaction tests)
# Get these from https://my.telegram.org/apps using a test Telegram account.
# =============================================================================

TELETHON_API_ID=0
TELETHON_API_HASH=dev-telethon-api-hash-change-me
TELETHON_SESSION_STRING=dev-telethon-session-string-change-me
