# Local development environment — copy to .dev.vars and fill in your values.
# .dev.vars is gitignored. Never commit real secrets.
#
# For staging/production: secrets go into Cloudflare Workers (wrangler secret put)
# and GitHub Actions. See docs/ops/secrets-inventory.md for the full map.

# =============================================================================
# Secrets (local dev: use fake/generated values, never real staging/prod keys)
# =============================================================================

# Operator write auth token — any random string for local dev
OPERATOR_TOKEN=dev-operator-token-change-me

# Helius — use fake values or skip for local dev
HELIUS_API_KEY=skip-helius-key
HELIUS_RPC_URL=https://api.devnet.solana.com
HELIUS_WEBHOOK_AUTH_HEADER=Bearer dev-webhook-secret-change-me

# Anchor wallet — generate a local keypair or use devnet throwaway
ANCHOR_WALLET_SECRET=dev-anchor-key-change-me

# Telegram bot — fake values, never real bot tokens
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TG_WEBHOOK_SECRET=dev-webhook-secret-change-me

# Bot identity protection — generate random 32-byte keys
TG_ID_HMAC_KEY=dev-hmac-key-change-me-32-bytes-min
TG_CHAT_ENC_KEY=dev-aes256-gcm-key-change-me-32-bytes

# =============================================================================
# Env specific values
# =============================================================================

SITE_URL=http://localhost:5173
SOLANA_CLUSTER=localnet
TREASURY_WALLET_ADDRESS=generate-me-for-localnet
VAULT_USDC_ATA=generate-me-for-localnet
ANCHOR_WALLET_ADDRESS=generate-me-for-localnet

# =============================================================================
# Public config (non-secrets, safe to commit — these are defaults for local dev)
# =============================================================================

USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
CONTACT_URL=https://t.me/your-contact-channel
